# INEP Data Source
INEP_DATA_URL_BASE=https://download.inep.gov.br/microdados/

# AWS S3 (Se aplicável no futuro)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google BigQuery (Se aplicável no futuro)
BIGQUERY_PROJECT_ID=

# Configurações Locais
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# CORS — origens permitidas para a API (JSON list). Em produção, restrinja ao seu domínio.
# CORS_ORIGINS=["https://meusite.com.br"]

# JupyterLab — obrigatório. Use um token forte (o quick_start.sh gera um automaticamente).
JUPYTER_TOKEN=troque_por_um_token_seguro

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
